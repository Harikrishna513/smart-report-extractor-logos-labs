{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd frontend && npm ci && npm run build",
  "outputDirectory": "frontend/.next",
  "installCommand": "cd frontend && npm ci && pip install ../backend",
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "excludeFiles": "{backend/tests/**,medical-pdf/**,**/fixtures/**}"
    }
  },
  "rewrites": [
    { "source": "/api/v1/(.*)", "destination": "/api/index.py" },
    { "source": "/api/docs", "destination": "/api/index.py" },
    { "source": "/api/redoc", "destination": "/api/index.py" },
    { "source": "/api/openapi.json", "destination": "/api/index.py" }
  ]
}
