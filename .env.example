# Gemini API key — required for document summaries (optional for local dev without summaries)
GEMINI_API_KEY=AQ.your-auth-key-or-AIzaSy-your-standard-key
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_TIMEOUT_SECONDS=30
GEMINI_SUMMARY_MAX_CHARS=500

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Set false on Vercel (Tesseract not available in serverless)
OCR_ENABLED=true
OCR_MAX_PAGES=25
TESSERACT_CMD=
GEMINI_OCR_ENABLED=true
GEMINI_OCR_MODEL=gemini-2.5-flash-lite

# Frontend (local dev only — copy to frontend/.env.local; not needed on Vercel)
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
